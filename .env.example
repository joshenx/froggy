# Supabase REST API settings for the waitlist endpoint.
# Prefer SUPABASE_SERVICE_ROLE_KEY in Vercel server env vars if available.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Alternative: use anon key with the insert-only RLS policy in supabase/schema.sql.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
